enum Site_type {
  LHS
  RHS
  BHS
  NONE
}

model DPR {
  id Int @id @default(autoincrement())

  date             DateTime
  project_id       Int
  submitted_by     Int
  company_id       Int
  head_office_id   Int
  branch_office_id Int
  company          Company      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  headOffice       HeadOffice   @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branchOffice     BranchOffice @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)

  project Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [submitted_by], references: [id], onDelete: Cascade)
  entries DPRChainage[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([project_id])
  @@index([date])
  @@map("dprs")
}

model DPRChainage {
  id Int @id @default(autoincrement())

  dpr_id Int
  dpr    DPR @relation(fields: [dpr_id], references: [id], onDelete: Cascade)

  site          Site_type? @default(NONE)
  chainage_from String?
  chainge_to    String?
  category_id   Int?
  category      Category?  @relation(fields: [category_id], references: [id], onDelete: Cascade)

  activity_id Int
  activity    Activity @relation(fields: [activity_id], references: [id], onDelete: Cascade)

  material_id Int?
  material    Material? @relation(fields: [material_id], references: [id], onDelete: Cascade)

  number Int?
  length Int?
  width  Int?
  depth  Int?

  unit_id Int
  unit    Unit @relation(fields: [unit_id], references: [id], onDelete: Cascade)

  quantity         Int?
  plan_quantity    Int?
  work_description String?
  boq_rate         Int?
  amount           Int?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  images     DPRFile[]

  @@index([dpr_id])
  @@map("dpr_chainages")
}

model DPRFile {
  id      Int @id @default(autoincrement())
  dpr_id  Int
  file_id Int

  file File        @relation(fields: [file_id], references: [id], onDelete: Cascade)
  dpr  DPRChainage @relation(fields: [dpr_id], references: [id], onDelete: Cascade)

  @@unique([dpr_id, file_id])
  @@map("dpr_files")
}

enum ReceiptStatus {
  RECEIVED
  ACCEPTED
  REJECTED
  PARTIALLY_ACCEPTED
  PENDING
}

model GRN {
  id Int @id @default(autoincrement())

  po_id             Int
  gate_entry_number String?
  vehicle_number    String?
  driver_name       String?
  driver_contact    String?

  transport_mode TransportMode?
  status         ReceiptStatus
  received_date  DateTime
  received_time  String?

  quality_check_completed Boolean              @default(false)
  grn_remarks             String?
  total_amount            Int?
  total_qty               Int?
  total_rejected          Int?
  total_received          Int?
  grn_number              String?
  warehouse_id            Int?
  warehouse               Warehouse?           @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
  company_id              Int
  head_office_id          Int
  branch_office_id        Int
  company                 Company              @relation(fields: [company_id], references: [id], onDelete: Cascade)
  headOffice              HeadOffice           @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branchOffice            BranchOffice         @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  material_receipts       GRNMaterialReceipt[]
  purchase_order          PO                   @relation(fields: [po_id], references: [id], onDelete: Cascade)
  created_by_id           Int?
  created_by              User?                @relation(fields: [created_by_id], references: [id], onDelete: Cascade)
  created_at              DateTime             @default(now())
  updated_at              DateTime             @updatedAt
  grnfiles                GRNFile[]
  invoices                invoice[]

  @@index([po_id])
  @@map("grn")
}

model GRNMaterialReceipt {
  id Int @id @default(autoincrement())

  grn_id      Int
  material_id Int
  ordered     Int
  chainage    String?
  quality     String? // Good / Damaged / Failed Test etc.
  rejected    Int
  received    Int
  rate        Int?
  amount      Int?
  quantity    Int?
  hsn_no      String?
  grn         GRN      @relation(fields: [grn_id], references: [id], onDelete: Cascade)
  material    Material @relation(fields: [material_id], references: [id])

  created_at DateTime @default(now())

  @@map("grn_matrial_receipt")
}

model GRNFile {
  id Int @id @default(autoincrement())

  grn_id  Int
  file_id Int

  grn  GRN  @relation(fields: [grn_id], references: [id], onDelete: Cascade)
  file File @relation(fields: [file_id], references: [id], onDelete: Cascade)

  @@unique([grn_id, file_id])
  @@map("grn_file")
}

enum POStatus {
  DRAFT
  ISSUED
  PARTIALLY_DELIVERED
  DELIVERED
  CANCELLED
  CLOSED
}

enum TransportMode {
  ROAD
  RAIL
  SEA
  AIR
  SELF_PICKUP
}

enum POType {
  ON_SITE
  INVENTORY
}

model PO {
  id Int @id @default(autoincrement())

  pr_id                  Int
  project_id             Int
  vendor_id              Int
  po_code                String         @unique
  po_date                DateTime       @default(now())
  expected_delivery_date DateTime?
  transport_mode         TransportMode?
  total_amount           String
  gst_percent            String?
  gst_amount             String?
  po_status              POStatus       @default(DRAFT)
  po_type                POType         @default(INVENTORY)
  payment_terms          String?
  delivery_terms         String?
  shipping_address       String?
  billing_address        String?
  remarks                String?
  company_id             Int
  head_office_id         Int
  branch_office_id       Int
  company                Company        @relation(fields: [company_id], references: [id], onDelete: Cascade)
  headOffice             HeadOffice     @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branchOffice           BranchOffice   @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  grns                   GRN[]
  order_items            POOrderItem[]
  pr                     PR             @relation(fields: [pr_id], references: [id])
  project                Project        @relation(fields: [project_id], references: [id])
  vendor                 Vendor         @relation(fields: [vendor_id], references: [id])
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt

  @@index([pr_id])
  @@index([project_id])
  @@index([vendor_id])
  @@map("pos")
}

model POOrderItem {
  id Int @id @default(autoincrement())

  po_id       Int
  material_id Int
  quantity    String
  rate        String
  amount      String
  hsn_no      String?
  po          PO       @relation(fields: [po_id], references: [id], onDelete: Cascade)
  material    Material @relation(fields: [material_id], references: [id])
  created_at  DateTime @default(now())

  @@map("po_order_items")
}

enum PRStatus {
  DRAFT
  SUBMITTED
  INVENTORY_CHECK
  PARTIAL_AVAILABLE
  PROCUREMENT_REQUIRED
  APPROVED
  REJECTED
  CLOSED
}

enum PRType {
  INVENTORY
  PROCUREMENT
  NONE
}

model PR {
  id               Int              @id @default(autoincrement())
  project_id       Int
  pr_code          String           @unique
  pr_type          PRType           @default(NONE)
  status           PRStatus         @default(DRAFT)
  remarks          String?
  user_id          Int? // Created by
  approved_by      Int? // Approver (User ID)
  send_to          Int?
  user             User?            @relation("CreatedBy", fields: [user_id], references: [id])
  approval_user    User?            @relation("approvalUser", fields: [send_to], references: [id])
  approvedUser     User?            @relation("ApprovedBy", fields: [approved_by], references: [id])
  company_id       Int
  company          Company          @relation(fields: [company_id], references: [id], onDelete: Cascade)
  head_office_id   Int
  headOffice       HeadOffice       @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branch_office_id Int
  branchOffice     BranchOffice     @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  material_items   PRMaterialItem[]
  project          Project          @relation(fields: [project_id], references: [id])
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  pos              PO[]
  prgrns           PRGRN[]

  @@index([project_id])
  @@index([user_id])
  @@map("prs")
}

model PRMaterialItem {
  id    Int @id @default(autoincrement())
  pr_id Int

  material_id      Int
  quantity         String
  required_date    DateTime
  is_approved      Boolean  @default(false)
  approved_qty     String?
  approval_remarks String?
  pr               PR       @relation(fields: [pr_id], references: [id], onDelete: Cascade)
  material         Material @relation(fields: [material_id], references: [id])

  created_at DateTime @default(now())

  @@map("pr_material_items")
}

model Activity {
  id                         Int                        @id @default(autoincrement())
  name                       String
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  dprchainages               DPRChainage[]
  workScopeItems             WorkScopeItem[]
  dieselConsumptions         diesel_consumption[]
  unit                       Unit?                      @relation(fields: [unitId], references: [id])
  unitId                     Int?
  labourAttendanceActivities LabourAttendanceActivity[]

  @@map("activities")
}

model BranchOffice {
  id                           Int                         @id @default(autoincrement())
  company_id                   Int
  company                      Company                     @relation(fields: [company_id], references: [id], onDelete: Cascade)
  head_office_id               Int
  headOffice                   HeadOffice                  @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  office_name                  String
  office_id                    String
  address                      String
  pincode                      String
  state                        String
  city                         String
  phone_number                 String
  mail_id                      String
  office_incharge_name         String?
  office_incharge_phone_number String?
  office_incharge_mail_id      String?
  created_at                   DateTime                    @default(now())
  updated_at                   DateTime                    @updatedAt
  users                        User[]
  workScopes                   WorkScope[]
  subContractorWorkOrders      sub_contractor_work_order[]
  warehouses                   Warehouse[]
  stocks                       Stock[]
  prs                          PR[]
  pos                          PO[]
  dieselConsumptions           diesel_consumption[]
  dieselInwards                DieselInward[]
  dprs                         DPR[]
  grns                         GRN[]
  invoices                     invoice[]
  machines                     Machine[]
  prgrns                       PRGRN[]
  dieselStocks                 DieselStock[]
  materialBoqs                 MaterialBoq[]
  vendors                      Vendor[]
  projects                     Project[]

  @@map("branch_office")
}

model Category {
  id                Int                @id @default(autoincrement())
  name              String
  description       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  dprchainages      DPRChainage[]
  projectCategories project_category[]

  @@map("categories")
}

model project_category {
  id          Int      @id @default(autoincrement())
  project_id  Int
  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  category_id Int
  category    Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@map("project_category")
}

model Company {
  id                      Int                         @id @default(autoincrement())
  company_name            String
  pincode                 String
  state                   String
  district                String
  address                 String
  company_mail_id         String
  company_phone_number    String
  company_gst_number      String
  business_type           String
  user_id                 Int
  user                    User                        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at              DateTime                    @default(now())
  updated_at              DateTime                    @updatedAt
  owner_id                Int?
  ownerDetails            owner_details?              @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  companyFiles            company_files[]
  headOffices             HeadOffice[]
  branchOffices           BranchOffice[]
  users                   User[]                      @relation(name: "company_users")
  workScopes              WorkScope[]
  subContractorWorkOrders sub_contractor_work_order[]
  warehouses              Warehouse[]
  stocks                  Stock[]
  prs                     PR[]
  pos                     PO[]
  dieselConsumptions      diesel_consumption[]
  dieselInwards           DieselInward[]
  dprs                    DPR[]
  grns                    GRN[]
  invoices                invoice[]
  machines                Machine[]
  prgrns                  PRGRN[]
  dieselStocks            DieselStock[]
  materialBoqs            MaterialBoq[]
  vendors                 Vendor[]
  projects                Project[]

  @@map("companies")
}

model owner_details {
  id                 Int       @id @default(autoincrement())
  owner_name         String
  owner_father_name  String
  dob                DateTime
  pincode            String
  state              String
  district           String
  address            String
  owner_phone_number String
  owner_mail_id      String
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  companies          Company[]

  @@map("owner_details")
}

model company_files {
  id         Int      @id @default(autoincrement())
  company_id Int
  company    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  file_id    Int
  file       File     @relation(fields: [file_id], references: [id], onDelete: Cascade)
  file_type  String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("company_files")
}

model diesel_consumption {
  id                     Int                       @id @default(autoincrement())
  machine_id             Int
  activity_id            Int
  diesel_used_liters     Int
  hours_used             Int
  operator_name          String
  date                   DateTime
  issued_by              Int
  remarks                String
  project_id             Int
  company_id             Int
  head_office_id         Int
  branch_office_id       Int
  company                Company                   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  headOffice             HeadOffice                @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branchOffice           BranchOffice              @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  project                Project                   @relation(fields: [project_id], references: [id])
  machine                Machine                   @relation(fields: [machine_id], references: [id])
  activity               Activity                  @relation(fields: [activity_id], references: [id])
  user                   User                      @relation(fields: [issued_by], references: [id])
  created_at             DateTime                  @default(now())
  updated_at             DateTime                  @updatedAt
  dieselConsumptionFiles diesel_consumption_file[]

  @@map("diesel_consumption")
}

model diesel_consumption_file {
  id                    Int                @id @default(autoincrement())
  diesel_consumption_id Int
  file_id               Int
  diesel_consumption    diesel_consumption @relation(fields: [diesel_consumption_id], references: [id], onDelete: Cascade)
  file                  File               @relation(fields: [file_id], references: [id], onDelete: Cascade)
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt

  @@map("diesel_consumption_file")
}

model DieselSupplier {
  id             Int    @id @default(autoincrement())
  name           String
  contact_number String
  address        String

  diesel_inwards DieselInward[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("diesel_supplier")
}

enum DieselInwardStatus {
  PENDING
  RECEIVED
  CANCELLED
}

model DieselInward {
  id Int @id @default(autoincrement())

  supplier_id       Int
  supplier          DieselSupplier @relation(fields: [supplier_id], references: [id])
  store_location_id Int?
  store_location    Warehouse?     @relation(fields: [store_location_id], references: [id])
  quantity_litres   Float
  rate_per_litre    Float
  total_amount      Float

  delivery_person_name String?
  vehicle_number       String?
  received_by          Int?
  received             User?                @relation(fields: [received_by], references: [id])
  received_at          DateTime?
  status               DieselInwardStatus   @default(PENDING)
  invoiceNumber        String?
  remarks              String?
  company_id           Int
  head_office_id       Int
  branch_office_id     Int
  company              Company              @relation(fields: [company_id], references: [id], onDelete: Cascade)
  headOffice           HeadOffice           @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branchOffice         BranchOffice         @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  dieselInwardFiles    diesel_inward_file[]

  @@map("diesel_inward")
}

model diesel_inward_file {
  id               Int          @id @default(autoincrement())
  diesel_inward_id Int
  diesel_inward    DieselInward @relation(fields: [diesel_inward_id], references: [id])
  file_id          Int
  file             File         @relation(fields: [file_id], references: [id])

  @@map("diesel_inward_file")
}

model DieselStock {
  id                      Int          @id @default(autoincrement())
  warehouse_id            Int
  warehouse               Warehouse    @relation(fields: [warehouse_id], references: [id])
  current_quantity_litres Float
  tank_capacity_litres    Float?
  manager_id              Int
  manager                 User         @relation(fields: [manager_id], references: [id])
  company_id              Int
  head_office_id          Int
  branch_office_id        Int
  company                 Company      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  headOffice              HeadOffice   @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branchOffice            BranchOffice @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  @@map("diesel_stock")
}

model File {
  id           Int      @id @default(autoincrement())
  filename     String
  originalName String
  mimeType     String
  size         Int
  filePath     String
  fileContent  Bytes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users           User[]
  dprfiles        DPRFile[]
  grnfiles        GRNFile[]
  vendorDocuments VendorDocuments[]

  prgrnfiles             PRGRNFile[]
  projectFiles           ProjectFile[]
  tenders                tender[]
  companyFiles           company_files[]
  dieselConsumptionFiles diesel_consumption_file[]
  dieselInwardFiles      diesel_inward_file[]

  @@map("files")
}

model HeadOffice {
  id                           Int                         @id @default(autoincrement())
  company_id                   Int
  company                      Company                     @relation(fields: [company_id], references: [id], onDelete: Cascade)
  office_name                  String
  office_id                    String
  address                      String
  pincode                      String
  state                        String
  city                         String
  phone_number                 String
  mail_id                      String
  office_incharge_name         String?
  office_incharge_phone_number String?
  office_incharge_mail_id      String?
  created_at                   DateTime                    @default(now())
  updated_at                   DateTime                    @updatedAt
  branchOffices                BranchOffice[]
  users                        User[]
  workScopes                   WorkScope[]
  subContractorWorkOrders      sub_contractor_work_order[]
  warehouses                   Warehouse[]
  stocks                       Stock[]
  prs                          PR[]
  pos                          PO[]
  dieselConsumptions           diesel_consumption[]
  dieselInwards                DieselInward[]
  dprs                         DPR[]
  grns                         GRN[]
  invoices                     invoice[]
  machines                     Machine[]
  prgrns                       PRGRN[]
  dieselStocks                 DieselStock[]
  materialBoqs                 MaterialBoq[]
  vendors                      Vendor[]
  projects                     Project[]

  @@map("head_office")
}

model invoice {
  id               Int                   @id @default(autoincrement())
  invoice_number   String
  invoice_date     DateTime
  invoice_type     String
  irn              String?
  ack_no           String?
  ack_date         DateTime?
  eway_bill_no     String?
  place_of_supply  String?
  destination      String?
  vehicle_number   String?
  total_quantity   Float?
  total_amount     Float?
  round_off        Float?
  amount_in_words  String?
  company_id       Int
  head_office_id   Int
  branch_office_id Int
  company          Company               @relation(fields: [company_id], references: [id], onDelete: Cascade)
  headOffice       HeadOffice            @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branchOffice     BranchOffice          @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  grn_id           Int
  grn              GRN                   @relation(fields: [grn_id], references: [id], onDelete: Cascade)
  vendor_id        Int
  vendor           Vendor                @relation(fields: [vendor_id], references: [id], onDelete: Cascade)
  seller           invoice_seller?
  buyer            invoice_buyer?
  consignee        invoice_consignee?
  tax              invoice_tax?
  bank_details     invoice_bank_details?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("invoices")
}

model invoice_seller {
  id             Int      @id @default(autoincrement())
  invoice_id     Int      @unique
  invoice        invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  name           String
  address        String
  godown_address String?
  phone          String[]
  email          String?
  gstin          String?
  state          String?
  state_code     String?
  udyog_aadhar   String?
  pan            String?

  @@map("invoice_seller")
}

model invoice_buyer {
  id         Int     @id @default(autoincrement())
  invoice_id Int     @unique
  invoice    invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  name       String
  address    String?
  gstin      String?
  state      String?
  state_code String?

  @@map("invoice_buyer")
}

model invoice_consignee {
  id         Int     @id @default(autoincrement())
  invoice_id Int     @unique
  invoice    invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  name       String
  address    String?
  gstin      String?
  state      String?
  state_code String?

  @@map("invoice_consignee")
}

model invoice_tax {
  id             Int     @id @default(autoincrement())
  invoice_id     Int     @unique
  invoice        invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  taxable_amount Float?
  cgst_rate      Float?
  cgst_amount    Float?
  sgst_rate      Float?
  sgst_amount    Float?
  igst_rate      Float?
  igst_amount    Float?
  total_tax      Float?
  tax_in_words   String?

  @@map("invoice_tax")
}

model invoice_bank_details {
  id                  Int     @id @default(autoincrement())
  invoice_id          Int     @unique
  invoice             invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  account_holder_name String?
  bank_name           String?
  account_number      String?
  ifsc_code           String?
  branch              String?

  @@map("invoice_bank_details")
}

model LabourAttendance {
  id                         Int                        @id @default(autoincrement())
  project_id                 Int
  date                       DateTime
  team_name                  String
  project                    Project                    @relation(fields: [project_id], references: [id])
  labourAttendanceActivities LabourAttendanceActivity[]

  @@map("labour_attendance")
}

model LabourAttendanceActivity {
  id                   String           @id @default(uuid())
  activity_id          Int
  activity             Activity         @relation(fields: [activity_id], references: [id])
  labour_attendance_id Int
  labour_attendance    LabourAttendance @relation(fields: [labour_attendance_id], references: [id])

  @@map("labour_attendance_activity")
}

model Machine {
  id                   Int                   @id @default(autoincrement())
  name                 String
  type                 String
  is_owned             Boolean               @default(false)
  rent_per_hour        String?
  purchase_cost        String?
  machine_count        Int
  project_id           Int
  project              Project               @relation(fields: [project_id], references: [id])
  company_id           Int
  head_office_id       Int
  branch_office_id     Int
  company              Company               @relation(fields: [company_id], references: [id], onDelete: Cascade)
  headOffice           HeadOffice            @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branchOffice         BranchOffice          @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  created_at           DateTime              @default(now())
  updated_at           DateTime              @updatedAt
  dieselConsumptions   diesel_consumption[]
  machineryAllocations MachineryAllocation[]

  @@map("machines")
}

model Material {
  id                    Int                    @id @default(autoincrement())
  name                  String
  material_code         String?                @unique
  unitId                Int?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  unit                  Unit?                  @relation(fields: [unitId], references: [id])
  prmaterialItems       PRMaterialItem[]
  poorderItems          POOrderItem[]
  grnmaterialReceipts   GRNMaterialReceipt[]
  stocks                Stock[]
  prgrnmaterialReceipts PRGRNMaterialReceipt[]
  dprchainages          DPRChainage[]
  materialBoqItems      MaterialBoqItem[]
  workscopeMaterials    WorkscopeMaterial[]

  @@map("materials")
}

model MaterialBoq {
  id                      Int                         @id @default(autoincrement())
  project_id              Int
  company_id              Int
  head_office_id          Int
  branch_office_id        Int
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  materialBoqItems        MaterialBoqItem[]
  subContractorWorkOrders sub_contractor_work_order[]
  project                 Project                     @relation(fields: [project_id], references: [id])
  company                 Company                     @relation(fields: [company_id], references: [id], onDelete: Cascade)
  headOffice              HeadOffice                  @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branchOffice            BranchOffice                @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)

  @@map("material_boq")
}

model MaterialBoqItem {
  id                 Int                @id @default(autoincrement())
  material_boq_id    Int
  material_boq       MaterialBoq        @relation(fields: [material_boq_id], references: [id])
  item_no            String?
  material_id        Int?
  material           Material?          @relation(fields: [material_id], references: [id])
  unit_id            Int
  unit               Unit               @relation(fields: [unit_id], references: [id])
  item_description   String?
  scope_quantity     Float?
  purchased_quantity Float?
  balanced_quantity  Float?
  rate               Float?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  workOrderItems     work_order_items[]

  @@map("material_boq_item")
}

model Module {
  id          Int          @id @default(autoincrement())
  Name        String
  description String?
  permissions Permission[] @relation("PermissionModules")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("modules")
}

model Permission {
  id          Int      @id @default(autoincrement())
  action      String[]
  modules     Module[] @relation("PermissionModules")
  roles       Role[]   @relation("RolePermissions")
  title       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("permissions")
}

model PRGRN {
  id                      Int                    @id @default(autoincrement())
  gate_entry_number       String?
  vehicle_number          String?
  driver_name             String?
  driver_contact          String?
  transport_mode          TransportMode?
  status                  ReceiptStatus
  received_date           DateTime
  received_time           String?
  warehouse_id            Int?
  quality_check_completed Boolean                @default(false)
  grn_remarks             String?
  total_amount            Int?
  total_qty               Int?
  total_rejected          Int?
  total_received          Int?
  grn_number              String?
  company_id              Int
  head_office_id          Int
  branch_office_id        Int
  pr_id                   Int
  created_by_id           Int?
  company                 Company                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  headOffice              HeadOffice             @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branchOffice            BranchOffice           @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  material_receipts       PRGRNMaterialReceipt[]
  purchase_order          PR                     @relation(fields: [pr_id], references: [id], onDelete: Cascade)
  grnfiles                PRGRNFile[]
  created_by              User?                  @relation(fields: [created_by_id], references: [id], onDelete: Cascade)
  created_at              DateTime               @default(now())
  updated_at              DateTime               @updatedAt

  @@map("pr_grns")
}

model PRGRNMaterialReceipt {
  id          Int      @id @default(autoincrement())
  grn_id      Int
  material_id Int
  ordered     Int
  chainage    String?
  quality     String? // Good / Damaged / Failed Test etc.
  rejected    Int
  received    Int
  rate        Int?
  amount      Int?
  quantity    Int?
  hsn_no      String?
  grn         PRGRN    @relation(fields: [grn_id], references: [id], onDelete: Cascade)
  material    Material @relation(fields: [material_id], references: [id])

  created_at DateTime @default(now())

  @@map("pr_grn_material_receipt")
}

model PRGRNFile {
  id Int @id @default(autoincrement())

  grn_id  Int
  file_id Int
  grn     PRGRN @relation(fields: [grn_id], references: [id], onDelete: Cascade)
  file    File  @relation(fields: [file_id], references: [id], onDelete: Cascade)

  @@unique([grn_id, file_id])
  @@map("pr_grn_files")
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

model Project {
  id              Int          @id @default(autoincrement())
  project_type_id Int?
  project_type    ProjectType? @relation(fields: [project_type_id], references: [id], onDelete: Cascade)
  project_name    String
  project_code    String
  start_date      DateTime?
  end_date        DateTime?

  budget String?
  status ProjectStatus @default(PLANNED)

  client           String?
  description      String?
  progress         Int? // 0–100 %
  manager_id       Int?
  project_manager  User?        @relation(fields: [manager_id], references: [id])
  district         String?
  state            String?
  pincode          String?
  from_length      String?
  to_length        String?
  total_length     String?
  total_chainage   String[]
  company_id       Int
  head_office_id   Int
  branch_office_id Int
  company          Company      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  headOffice       HeadOffice   @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branchOffice     BranchOffice @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  prs        PR[]
  pos        PO[]
  dprs       DPR[]

  labourAttendances LabourAttendance[]

  project_files           ProjectFile[]
  materialBoqs            MaterialBoq[]
  workScopes              WorkScope[]
  subContractorWorkOrders sub_contractor_work_order[]
  projectCategories       project_category[]
  dieselConsumptions      diesel_consumption[]
  machines                Machine[]
  tenders                 tender[]

  @@map("project")
}

model ProjectFile {
  id         Int     @id @default(autoincrement())
  project_id Int
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  file_id    Int
  file       File    @relation(fields: [file_id], references: [id], onDelete: Cascade)

  @@map("project_file")
}

model ProjectType {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]

  @@map("project_types")
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  users       User[]

  permissions Permission[] @relation("RolePermissions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
// mcxc
generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum Provider {
  credentials
  google
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  RESERVED
  DAMAGED
  DISPOSED
}

model Stock {
  id                         Int          @id @default(autoincrement())
  material_id                Int
  warehouse_id               Int
  warehouse                  Warehouse    @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
  status                     StockStatus  @default(IN_STOCK)
  minimum_threshold_quantity Int?
  current_stock              Int?
  quantity                   Int?
  specifications             String?
  manager_id                 Int
  inventory_manager          User         @relation(fields: [manager_id], references: [id])
  company_id                 Int
  company                    Company      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  head_office_id             Int
  headOffice                 HeadOffice   @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branch_office_id           Int
  branchOffice               BranchOffice @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  material                   Material?    @relation(fields: [material_id], references: [id])

  @@map("stock")
}

enum work_order_status {
  PENDING
  APPROVED
  REJECTED
}

enum payment_status {
  PENDING
  PAID
  PARTIALLY_PAID
}

model sub_contractor_work_order {
  id                     Int                @id @default(autoincrement())
  project_id             Int
  vendor_id              Int
  materia_boq_id         Int
  work_order_no          String
  work_order_date        DateTime
  work_order_status      work_order_status?
  work_order_description String?
  work_order_amount      String?
  meta_data              Json?
  payment_status         payment_status     @default(PENDING)
  company_id             Int
  company                Company            @relation(fields: [company_id], references: [id], onDelete: Cascade)
  head_office_id         Int
  headOffice             HeadOffice         @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branch_office_id       Int
  branchOffice           BranchOffice       @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  project                Project            @relation(fields: [project_id], references: [id])
  vendor                 Vendor             @relation(fields: [vendor_id], references: [id])
  material_boq           MaterialBoq        @relation(fields: [materia_boq_id], references: [id])
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt
  workOrderItems         work_order_items[]

  @@map("sub_contractor_work_order")
}

model work_order_items {
  id                   Int                       @id @default(autoincrement())
  work_order_id        Int
  material_boq_item_id Int
  material_boq_item    MaterialBoqItem           @relation(fields: [material_boq_item_id], references: [id])
  work_order           sub_contractor_work_order @relation(fields: [work_order_id], references: [id], onDelete: Cascade)
  created_at           DateTime                  @default(now())
  updated_at           DateTime                  @updatedAt

  @@map("work_order_items")
}

model tender {
  id         Int      @id @default(autoincrement())
  file_id    Int
  file       File     @relation(fields: [file_id], references: [id], onDelete: Cascade)
  project_id Int?
  project    Project? @relation(fields: [project_id], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("tender")
}

model Unit {
  id                 Int                 @id @default(autoincrement())
  name               String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  materials          Material[]
  activities         Activity[]
  dprchainages       DPRChainage[]
  materialBoqItems   MaterialBoqItem[]
  workscopeMaterials WorkscopeMaterial[]

  @@map("units")
}

model User {
  id                Int     @id @default(autoincrement())
  name              String
  email             String  @unique
  emailVerified     Boolean @default(false)
  password          String
  fileId            Int?
  profileImage      File?   @relation(fields: [fileId], references: [id], onDelete: SetNull)
  original_password String?
  mobileNumber      String?
  roleId            Int?
  role              Role?   @relation(fields: [roleId], references: [id])
  company_id        Int?
  head_office_id    Int?
  branch_office_id  Int?

  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  provider           Provider             @default(credentials)
  company            Company?             @relation(name: "company_users", fields: [company_id], references: [id], onDelete: Cascade)
  headOffice         HeadOffice?          @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branchOffice       BranchOffice?        @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  prs_created_by     PR[]                 @relation("CreatedBy")
  prs_approved_by    PR[]                 @relation("ApprovedBy")
  prs                PR[]                 @relation("approvalUser")
  grns               GRN[]
  stocks             Stock[]
  dprs               DPR[]
  prgrns             PRGRN[]
  projects           Project[]
  dieselStocks       DieselStock[]
  dieselInwards      DieselInward[]
  dieselConsumptions diesel_consumption[]
  companies          Company[]

  @@map("users")
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VendorType {
  SUB_CONTRACTOR
  MATERIAL_SUPPLIER
}

model Vendor {
  id Int @id @default(autoincrement())

  // Vendor Details
  vendor_name        String
  proprietor_name    String?
  contact_person     String?
  contact_number     String
  email_address      String?
  address            String
  registered_address String?

  vendor_type      VendorType?
  status           VendorStatus            @default(ACTIVE)
  company_id       Int?
  company          Company?                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  head_office_id   Int?
  headOffice       HeadOffice?             @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branch_office_id Int?
  branchOffice     BranchOffice?           @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  bankDetails      VendorBankDetails?
  financialDetails VendorFinancialDetails?
  otherDetails     VendorOtherDetails?
  documents        VendorDocuments[]
  pos              PO[]

  created_at              DateTime                    @default(now())
  updated_at              DateTime                    @updatedAt
  subContractorWorkOrders sub_contractor_work_order[]
  invoices                invoice[]

  @@map("vendor")
}

model VendorBankDetails {
  id       Int @id @default(autoincrement())
  vendorId Int @unique

  bank_name           String
  branch_name         String?
  bank_address        String?
  bank_contact_number String?

  account_number String
  ifsc_code      String
  micr_code      String?
  rtgs_code      String?
  neft_code      String?

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vendor_bank_details")
}

model VendorFinancialDetails {
  id       Int @id @default(autoincrement())
  vendorId Int @unique

  registration_number String?
  pan_number          String
  esi_number          String?
  pf_number           String?
  gst_number          String?
  gst_state           String?

  annual_turnover       String?
  audited_balance_years String?
  yearly_work_capacity  String?

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vendor_financial_details")
}

model VendorOtherDetails {
  id       Int @id @default(autoincrement())
  vendorId Int @unique

  organization_type   String?
  total_team_size     String?
  plant_and_machinery String?
  organization_chart  String?

  interested_other_work String?
  association_status    String?
  geographical_presence String?
  major_clients         String?

  sop_qap_signoff     String?
  sop_quality_manual  String?
  relative_experience String?

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vendor_other_details")
}

model VendorDocuments {
  id            Int     @id @default(autoincrement())
  vendorId      Int
  file_id       Int?
  document_type String?

  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  file      File?    @relation(fields: [file_id], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vendor_documents")
}

model Warehouse {
  id               Int            @id @default(autoincrement())
  name             String
  address          String
  state            String
  pincode          String
  district         String
  company_id       Int
  company          Company        @relation(fields: [company_id], references: [id], onDelete: Cascade)
  head_office_id   Int
  headOffice       HeadOffice     @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branch_office_id Int
  branchOffice     BranchOffice   @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  stocks           Stock[]
  dieselStocks     DieselStock[]
  dieselInwards    DieselInward[]
  grns             GRN[]

  @@map("warehouses")
}

model WorkScope {
  id               Int             @id @default(autoincrement())
  project_id       Int
  project          Project         @relation(fields: [project_id], references: [id])
  company_id       Int
  company          Company         @relation(fields: [company_id], references: [id], onDelete: Cascade)
  head_office_id   Int
  headOffice       HeadOffice      @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
  branch_office_id Int
  branchOffice     BranchOffice    @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  workScopeItems   WorkScopeItem[]

  @@map("workscope")
}

model WorkScopeItem {
  id                   Int                   @id @default(autoincrement())
  workscope_id         Int
  workscope            WorkScope             @relation(fields: [workscope_id], references: [id], onDelete: Cascade)
  activity_id          Int
  activity             Activity              @relation(fields: [activity_id], references: [id])
  quantity             Float?
  status               WorkScopeStatus       @default(PENDING)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  start_date           DateTime?
  end_date             DateTime?
  // Relations
  WorkscopeMaterials   WorkscopeMaterial[]
  labourAllocations    LabourAllocation[]
  machineryAllocations MachineryAllocation[]

  @@map("workscope_item")
}

// Material consumption for each activity
model WorkscopeMaterial {
  id                Int           @id @default(autoincrement())
  workscope_item_id Int
  workscopeItem     WorkScopeItem @relation(fields: [workscope_item_id], references: [id], onDelete: Cascade)
  material_id       Int
  material          Material      @relation(fields: [material_id], references: [id])
  quantity          Float?
  unit_id           Int
  unit              Unit          @relation(fields: [unit_id], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("material_consumption")
}

// Labour allocation for each activity
model LabourAllocation {
  id                Int           @id @default(autoincrement())
  workscope_item_id Int
  workscopeItem     WorkScopeItem @relation(fields: [workscope_item_id], references: [id], onDelete: Cascade)
  labour_type       String?
  count             Int?
  days              Int?
  rate_per_day      Float?
  total_cost        Float?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("labour_allocation")
}

// Machinery allocation for each activity
model MachineryAllocation {
  id                Int           @id @default(autoincrement())
  workscope_item_id Int
  workscopeItem     WorkScopeItem @relation(fields: [workscope_item_id], references: [id], onDelete: Cascade)
  machine_id        Int
  machine           Machine       @relation(fields: [machine_id], references: [id])
  count             Int?
  hours             Float?
  rate_per_hour     Float?
  total_cost        Float?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("machinery_allocation")
}

// Enum for WorkScope Item Status
enum WorkScopeStatus {
  PENDING
  CONFIGURED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}
