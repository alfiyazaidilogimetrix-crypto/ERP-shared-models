model File {
    id           Int      @id @default(autoincrement())
    filename     String
    originalName String
    mimeType     String
    size         Int
    filePath     String
    fileContent  Bytes
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    users           User[]
    dprfiles        DPRFile[]
    grnfiles        GRNFile[]
    vendorDocuments VendorDocuments[]

    prgrnfiles             PRGRNFile[]
    projectFiles           ProjectFile[]
    tenders                tender[]
    companyFiles           company_files[]
    dieselConsumptionFiles diesel_consumption_file[]
    dieselInwardFiles      diesel_inward_file[]
    companies              Company[]

    @@map("files")
}
