enum StockStatus {
    IN_STOCK
    LOW_STOCK
    OUT_OF_STOCK
    RESERVED
    DAMAGED
    DISPOSED
}

model Stock {
    id                Int             @id @default(autoincrement())
    warehouse_id      Int
    warehouse         Warehouse       @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
    manager_id        Int
    inventory_manager User            @relation(fields: [manager_id], references: [id])
    company_id        Int
    company           Company         @relation(fields: [company_id], references: [id], onDelete: Cascade)
    createdAt         DateTime        @default(now())
    updatedAt         DateTime        @updatedAt
    stockMaterials    stockMaterial[]

    @@map("stock")
}

model stockMaterial {
    id                         Int         @id @default(autoincrement())
    stock_id                   Int
    material_id                Int
    quantity                   Float?
    minimum_threshold_quantity Int?
    current_stock              Int?
    specifications             String?
    status                     StockStatus @default(IN_STOCK)
    stock                      Stock       @relation(fields: [stock_id], references: [id], onDelete: Cascade)
    material                   Material    @relation(fields: [material_id], references: [id], onDelete: Cascade)
    createdAt                  DateTime    @default(now())
    updatedAt                  DateTime    @updatedAt

    @@map("stock_material")
}
