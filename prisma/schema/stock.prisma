enum StockStatus {
    IN_STOCK
    LOW_STOCK
    OUT_OF_STOCK
    RESERVED
    DAMAGED
    DISPOSED
}

model Stock {
    id                         Int          @id @default(autoincrement())
    material_id                Int
    warehouse_id               Int
    warehouse                  Warehouse    @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
    status                     StockStatus  @default(IN_STOCK)
    minimum_threshold_quantity Int?
    current_stock              Int?
    quantity                   Int?
    specifications             String?
    manager_id                 Int
    inventory_manager          User         @relation(fields: [manager_id], references: [id])
    company_id                 Int
    company                    Company      @relation(fields: [company_id], references: [id], onDelete: Cascade)
    head_office_id             Int
    headOffice                 HeadOffice   @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
    branch_office_id           Int
    branchOffice               BranchOffice @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
    createdAt                  DateTime     @default(now())
    updatedAt                  DateTime     @updatedAt
    material                   Material?    @relation(fields: [material_id], references: [id])

    @@map("stock")
}
