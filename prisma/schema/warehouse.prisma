model Warehouse {
    id               Int            @id @default(autoincrement())
    name             String
    address          String
    state            String
    pincode          String
    district         String
    company_id       Int
    company          Company        @relation(fields: [company_id], references: [id], onDelete: Cascade)
    createdAt        DateTime       @default(now())
    updatedAt        DateTime       @updatedAt
    stocks           Stock[]
    dieselStocks     DieselStock[]
    dieselInwards    DieselInward[]
    grns             GRN[]

    @@map("warehouses")
}
