model WorkScope {
    id               Int             @id @default(autoincrement())
    project_id       Int
    project          Project         @relation(fields: [project_id], references: [id])
    company_id       Int
    company          Company         @relation(fields: [company_id], references: [id], onDelete: Cascade)
    head_office_id   Int
    headOffice       HeadOffice      @relation(fields: [head_office_id], references: [id], onDelete: Cascade)
    branch_office_id Int
    branchOffice     BranchOffice    @relation(fields: [branch_office_id], references: [id], onDelete: Cascade)
    createdAt        DateTime        @default(now())
    updatedAt        DateTime        @updatedAt
    workScopeItems   WorkScopeItem[]

    @@map("workscope")
}

model WorkScopeItem {
    id                   Int                   @id @default(autoincrement())
    workscope_id         Int
    workscope            WorkScope             @relation(fields: [workscope_id], references: [id], onDelete: Cascade)
    activity_id          Int
    activity             Activity              @relation(fields: [activity_id], references: [id])
    quantity             Float?
    executed_quantity    Float?
    balanced_quantity    Float?
    status               WorkScopeStatus       @default(PENDING)
    createdAt            DateTime              @default(now())
    updatedAt            DateTime              @updatedAt
    start_date           DateTime?
    end_date             DateTime?
    // Relations
    WorkscopeMaterials   WorkscopeMaterial[]
    labourAllocations    LabourAllocation[]
    machineryAllocations MachineryAllocation[]

    @@map("workscope_item")
}

// Material consumption for each activity
model WorkscopeMaterial {
    id                      Int                      @id @default(autoincrement())
    workscope_item_id       Int
    workscopeItem           WorkScopeItem            @relation(fields: [workscope_item_id], references: [id], onDelete: Cascade)
    material_id             Int
    material                Material                 @relation(fields: [material_id], references: [id])
    quantity                Float?
    unit_id                 Int
    unit                    Unit                     @relation(fields: [unit_id], references: [id])
    createdAt               DateTime                 @default(now())
    updatedAt               DateTime                 @updatedAt
    dprMaterialConsumptions DPRMaterialConsumption[]

    @@map("material_consumption")
}

// Labour allocation for each activity
model LabourAllocation {
    id                Int           @id @default(autoincrement())
    workscope_item_id Int
    workscopeItem     WorkScopeItem @relation(fields: [workscope_item_id], references: [id], onDelete: Cascade)
    labour_type       String?
    count             Int?
    days              Int?
    rate_per_day      Float?
    total_cost        Float?
    createdAt         DateTime      @default(now())
    updatedAt         DateTime      @updatedAt

    @@map("labour_allocation")
}

// Machinery allocation for each activity
model MachineryAllocation {
    id                Int           @id @default(autoincrement())
    workscope_item_id Int
    workscopeItem     WorkScopeItem @relation(fields: [workscope_item_id], references: [id], onDelete: Cascade)
    machine_id        Int
    machine           Machine       @relation(fields: [machine_id], references: [id])
    count             Int?
    hours             Float?
    rate_per_hour     Float?
    total_cost        Float?
    createdAt         DateTime      @default(now())
    updatedAt         DateTime      @updatedAt

    @@map("machinery_allocation")
}

// Enum for WorkScope Item Status
enum WorkScopeStatus {
    PENDING
    CONFIGURED
    IN_PROGRESS
    COMPLETED
    ON_HOLD
}
