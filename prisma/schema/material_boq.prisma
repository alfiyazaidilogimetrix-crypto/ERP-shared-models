model MaterialBoq {
  id                      Int                         @id @default(autoincrement())
  project_id              Int
  company_id              Int
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  materialBoqItems        MaterialBoqItem[]
  subContractorWorkOrders sub_contractor_work_order[]
  project                 Project                     @relation(fields: [project_id], references: [id])
  company                 Company                     @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("material_boq")
}

model MaterialBoqItem {
  id                 Int                @id @default(autoincrement())
  material_boq_id    Int
  material_boq       MaterialBoq        @relation(fields: [material_boq_id], references: [id])
  item_no            String?
  material_id        Int?
  material           Material?          @relation(fields: [material_id], references: [id])
  unit_id            Int
  unit               Unit               @relation(fields: [unit_id], references: [id])
  item_description   String?
  scope_quantity     Float?
  purchased_quantity Float?
  balanced_quantity  Float?
  rate               Float?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  workOrderItems     work_order_items[]

  @@map("material_boq_item")
}
